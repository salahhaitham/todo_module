<odoo>
    <record id="tasks_tree_view_id" model="ir.ui.view">
        <field name="name">task view</field>
        <field name="model">task</field>
        <field name="arch" type="xml">
            <list string="Tasks">
                <field name="task_name"/>
                <field name="assign_to"/>
                <field name="description"/>
                <field name="due_date"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="tasks_form_view_id" model="ir.ui.view">
        <field name="name">task view</field>
        <field name="model">task</field>
        <field name="arch" type="xml">
            <form string="Task">
                <sheet>
                    <group>
                        <field name="task_name"/>
                        <field name="assign_to"/>
                        <field name="description"/>
                        <field name="due_date"/>
                        <field name="status"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
       <record id="tasks_search_view_id" model="ir.ui.view">
        <field name="name">task view</field>
        <field name="model">task</field>
        <field name="arch" type="xml">
            <search string="search">


                        <field name="task_name"/>
                 <field name="assign_to"/>
                       <filter name="status" string="inprogress" domain="[('status' ,'=','inprogress')]"/>
                <filter name="status" string="new" domain="[('status' ,'=','new')]"/>
                <filter name="status" string="done" domain="[('status' ,'=','done')]"/>

                <filter name="status" string="status" context="{'group_by':'status'}"/>
                <filter name="status" string="date" context="{'group_by':'due_date'}"/>
                <filter name="status" string="assign_to" context="{'group_by':'assign_to'}"/>

            </search>
        </field>
    </record>

    <record id="all_tasks_action" model="ir.actions.act_window">
        <field name="name">All Tasks</field>
        <field name="res_model">task</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem id="all_tasks_view_id" name="All Tasks" parent="tasks_view_id" action="all_tasks_action"/>
</odoo>
