<odoo>
    <record id="tasks_tree_view_id" model="ir.ui.view">
        <field name="name">task view</field>
        <field name="model">task</field>
        <field name="arch" type="xml">
            <list string="Tasks" decoration-danger="is_late">
                <field name="task_name"/>
                <field name="assign_to_id"/>
                <field name="description"/>
                <field name="due_date"/>
                <field name="is_late" invisible="True"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="tasks_form_view_id" model="ir.ui.view">
        <field name="name">task view</field>
        <field name="model">task</field>
        <field name="arch" type="xml">
            <form string="Task">
                <sheet>
                    <header>


    <!-- IN PROGRESS -->
    <button name="task_state_inprogress"
            string="In Progress"
            type="object"
            class="btn-primary"
            invisible="status != 'new'"/>

    <!-- DONE -->
    <button name="task_state_done"
            string="Done"
            type="object"
            class="btn-success"
            invisible="status != 'inprogress'"/>

    <field name="status" widget="statusbar"/>
</header>
                    <group>
                        <field name="task_name"/>

                        <field name="assign_to_id"/>
                        <field name="description"/>
                        <field name="due_date"/>
                        <field name="estimate_time"/>
                         <field name="total_time"/>
                    </group>
                        <notebook>
                 <page string="Task Lines">
                     <field name="task_lines_ids" >

                         <list editable="bottom">
                               <field name="line_description"></field>
                               <field name="line_time_takes"></field>
                         </list>
                     </field>
                 </page>
             </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
       <record id="tasks_search_view_id" model="ir.ui.view">
        <field name="name">task view</field>
        <field name="model">task</field>
        <field name="arch" type="xml">
            <search string="search">


                        <field name="task_name"/>
                 <field name="assign_to_id"/>
                       <filter name="status" string="inprogress" domain="[('status' ,'=','inprogress')]"/>
                <filter name="status" string="new" domain="[('status' ,'=','new')]"/>
                <filter name="status" string="done" domain="[('status' ,'=','done')]"/>

                <filter name="status" string="status" context="{'group_by':'status'}"/>
                <filter name="status" string="date" context="{'group_by':'due_date'}"/>
                <filter name="status" string="assign_to" context="{'group_by':'assign_to_id'}"/>

            </search>
        </field>
    </record>


    <record id="task_automated_action" model="ir.cron">
        <field name="name">check TaskTimeValidator</field>
        <field name="model_id" ref="model_task"></field>
         <field name="binding_model_id" ref="model_task"></field>
        <field name="state" >code</field>
        <field name="code">model.check_date_validator()</field>
         <field name="interval_number" >1</field>
        <field name="interval_type" >days</field>
        <field name="active" >True</field>

    </record>


    <record id="all_tasks_action" model="ir.actions.act_window">
        <field name="name">All Tasks</field>
        <field name="res_model">task</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem id="all_tasks_view_id" name="All Tasks" parent="tasks_view_id" action="all_tasks_action"/>

</odoo>
